# Strings
APP_ENV="development"
DB_HOST="localhost"

# Integers (Whole Numbers)
SERVER_PORT=8080
MAX_CONNECTIONS=5

# Floats (Decimal Numbers)
TIMEOUT_LIMIT=4.5
TAX_RATE=0.15

# Booleans (True/False)
DEBUG=true
ENABLE_SIGNUPS=false

# Tuples (Immutable Sequences)
ALLOWED_COLORS="red,green,blue"
DATABASE_COORDINATES="45.12,-122.33"
ADMIN_IDS="(1001, 1002, 1003)"

#lists (Mutable Sequences)
FRUITS="apple,banana,cherry"
PRIME_NUMBERS="2,3,5,7"
USER_ROLES='["admin", "editor", "viewer"]'

# dictionary using JSON format
APP_CONFIG_JSON='{"theme": "dark", "retries": 3, "debug": true}'

# dictionary using Python literal format
APP_CONFIG='{"theme": "dark", "retries": 3, "debug": True}'

# dictionary using prefix
DB_HOST="localhost"
DB_PORT=5432
DB_USER="admin"